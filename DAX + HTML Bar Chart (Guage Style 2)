Injury Risk Distribution Visual = 
VAR _Total = [Players]
VAR _Low = CALCULATE([Players], DimPlayer[InjuryRisk] = "Low Risk")
VAR _Mod = CALCULATE([Players], DimPlayer[InjuryRisk] = "Moderate Risk")
VAR _High = CALCULATE([Players], DimPlayer[InjuryRisk] = "High Risk")
VAR _Crit = CALCULATE([Players], DimPlayer[InjuryRisk] = "Critical Risk")
VAR _LowPct = ROUND(DIVIDE(_Low, _Total, 0) * 100, 0)
VAR _ModPct = ROUND(DIVIDE(_Mod, _Total, 0) * 100, 0)
VAR _HighPct = ROUND(DIVIDE(_High, _Total, 0) * 100, 0)
VAR _CritPct = ROUND(DIVIDE(_Crit, _Total, 0) * 100, 0)
RETURN
"<style>
  .rd{font-family:Segoe UI,sans-serif;padding:8px 14px;width:100%;height:100%}
  .rd-t{font-size:14px;font-weight:800;color:#1a2b4a;margin-bottom:8px}
  .rd-row{display:flex;align-items:center;gap:10px;margin-bottom:6px;padding:8px 10px;background:#f3f5f7;border-radius:10px}
  .rd-info{flex:1;min-width:0}
  .rd-top{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:4px}
  .rd-name{font-size:12px;font-weight:700;color:#1a2b4a}
  .rd-pct{font-size:14px;font-weight:800;color:#1a2b4a}
  .rd-track{width:100%;height:8px;background:#e0e4e9;border-radius:5px;overflow:hidden}
  .rd-fill{height:100%;border-radius:5px}
  .rd-sub{font-size:12px;color:#8895a7;font-weight:500;margin-top:2px}
</style>
<div class='rd'>
  <div class='rd-t'>Risk Level Distribution</div>
  <div class='rd-row'>
    <div class='rd-info'>
      <div class='rd-top'><span class='rd-name'>Low Risk</span><span class='rd-pct'>" & _LowPct & "%</span></div>
      <div class='rd-track'><div class='rd-fill' style='width:" & _LowPct & "%;background:#22c55e'></div></div>
      <div class='rd-sub'>" & FORMAT(_Low, "#,0") & " of " & FORMAT(_Total, "#,0") & "</div>
    </div>
  </div>
  <div class='rd-row'>
    <div class='rd-info'>
      <div class='rd-top'><span class='rd-name'>Moderate Risk</span><span class='rd-pct'>" & _ModPct & "%</span></div>
      <div class='rd-track'><div class='rd-fill' style='width:" & _ModPct & "%;background:#F59E0B'></div></div>
      <div class='rd-sub'>" & FORMAT(_Mod, "#,0") & " of " & FORMAT(_Total, "#,0") & "</div>
    </div>
  </div>
  <div class='rd-row'>
    <div class='rd-info'>
      <div class='rd-top'><span class='rd-name'>High Risk</span><span class='rd-pct'>" & _HighPct & "%</span></div>
      <div class='rd-track'><div class='rd-fill' style='width:" & _HighPct & "%;background:#F97316'></div></div>
      <div class='rd-sub'>" & FORMAT(_High, "#,0") & " of " & FORMAT(_Total, "#,0") & "</div>
    </div>
  </div>
  <div class='rd-row'>
    <div class='rd-info'>
      <div class='rd-top'><span class='rd-name'>Critical Risk</span><span class='rd-pct'>" & _CritPct & "%</span></div>
      <div class='rd-track'><div class='rd-fill' style='width:" & _CritPct & "%;background:#D93025'></div></div>
      <div class='rd-sub'>" & FORMAT(_Crit, "#,0") & " of " & FORMAT(_Total, "#,0") & "</div>
    </div>
  </div>
</div>"
