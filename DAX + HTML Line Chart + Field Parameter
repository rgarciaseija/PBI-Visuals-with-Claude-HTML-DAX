Monthly Trend Visual = 
VAR _SelMeasure = MAX(Parameter[Parameter])
VAR _Sel = IF(ISBLANK(_SelMeasure), "Injuries", _SelMeasure)
VAR _Jan = CALCULATE(SWITCH(_Sel, "Injuries", [Recorded Injuries], "Total Cost", [Total Cost], "Recovery Days", [Average Days To Recovery]), 'Calendar'[Month Short] = "Jan")
VAR _Feb = CALCULATE(SWITCH(_Sel, "Injuries", [Recorded Injuries], "Total Cost", [Total Cost], "Recovery Days", [Average Days To Recovery]), 'Calendar'[Month Short] = "Feb")
VAR _Mar = CALCULATE(SWITCH(_Sel, "Injuries", [Recorded Injuries], "Total Cost", [Total Cost], "Recovery Days", [Average Days To Recovery]), 'Calendar'[Month Short] = "Mar")
VAR _Apr = CALCULATE(SWITCH(_Sel, "Injuries", [Recorded Injuries], "Total Cost", [Total Cost], "Recovery Days", [Average Days To Recovery]), 'Calendar'[Month Short] = "Apr")
VAR _May = CALCULATE(SWITCH(_Sel, "Injuries", [Recorded Injuries], "Total Cost", [Total Cost], "Recovery Days", [Average Days To Recovery]), 'Calendar'[Month Short] = "May")
VAR _Jun = CALCULATE(SWITCH(_Sel, "Injuries", [Recorded Injuries], "Total Cost", [Total Cost], "Recovery Days", [Average Days To Recovery]), 'Calendar'[Month Short] = "Jun")
VAR _Jul = CALCULATE(SWITCH(_Sel, "Injuries", [Recorded Injuries], "Total Cost", [Total Cost], "Recovery Days", [Average Days To Recovery]), 'Calendar'[Month Short] = "Jul")
VAR _Aug = CALCULATE(SWITCH(_Sel, "Injuries", [Recorded Injuries], "Total Cost", [Total Cost], "Recovery Days", [Average Days To Recovery]), 'Calendar'[Month Short] = "Aug")
VAR _Sep = CALCULATE(SWITCH(_Sel, "Injuries", [Recorded Injuries], "Total Cost", [Total Cost], "Recovery Days", [Average Days To Recovery]), 'Calendar'[Month Short] = "Sep")
VAR _Oct = CALCULATE(SWITCH(_Sel, "Injuries", [Recorded Injuries], "Total Cost", [Total Cost], "Recovery Days", [Average Days To Recovery]), 'Calendar'[Month Short] = "Oct")
VAR _Nov = CALCULATE(SWITCH(_Sel, "Injuries", [Recorded Injuries], "Total Cost", [Total Cost], "Recovery Days", [Average Days To Recovery]), 'Calendar'[Month Short] = "Nov")
VAR _Dec = CALCULATE(SWITCH(_Sel, "Injuries", [Recorded Injuries], "Total Cost", [Total Cost], "Recovery Days", [Average Days To Recovery]), 'Calendar'[Month Short] = "Dec")
VAR _Fmt = IF(_Sel = "Total Cost", "#,0", "#,0")
VAR _Title = SWITCH(_Sel, "Injuries", "Recorded Injuries", "Total Cost", "Total Treatment Cost", "Recovery Days", "Average Days To Recovery", "Recorded Injuries") & " Monthly Trend"
VAR _Max = MAX(_Jan, MAX(_Feb, MAX(_Mar, MAX(_Apr, MAX(_May, MAX(_Jun, MAX(_Jul, MAX(_Aug, MAX(_Sep, MAX(_Oct, MAX(_Nov, _Dec)))))))))))
VAR _Min = MIN(_Jan, MIN(_Feb, MIN(_Mar, MIN(_Apr, MIN(_May, MIN(_Jun, MIN(_Jul, MIN(_Aug, MIN(_Sep, MIN(_Oct, MIN(_Nov, _Dec)))))))))))
VAR _Pad = MAX(ROUND((_Max - _Min) * 0.15, 0), 1)
VAR _Top = _Max + _Pad
VAR _Bot = _Min - _Pad
VAR _Range = MAX(_Top - _Bot, 1)
VAR _H = 140
VAR _W = 480
VAR _Step = ROUND(_W / 11, 0)
VAR _Y1 = ROUND(_H - DIVIDE(_Jan - _Bot, _Range, 0) * _H + 20, 0)
VAR _Y2 = ROUND(_H - DIVIDE(_Feb - _Bot, _Range, 0) * _H + 20, 0)
VAR _Y3 = ROUND(_H - DIVIDE(_Mar - _Bot, _Range, 0) * _H + 20, 0)
VAR _Y4 = ROUND(_H - DIVIDE(_Apr - _Bot, _Range, 0) * _H + 20, 0)
VAR _Y5 = ROUND(_H - DIVIDE(_May - _Bot, _Range, 0) * _H + 20, 0)
VAR _Y6 = ROUND(_H - DIVIDE(_Jun - _Bot, _Range, 0) * _H + 20, 0)
VAR _Y7 = ROUND(_H - DIVIDE(_Jul - _Bot, _Range, 0) * _H + 20, 0)
VAR _Y8 = ROUND(_H - DIVIDE(_Aug - _Bot, _Range, 0) * _H + 20, 0)
VAR _Y9 = ROUND(_H - DIVIDE(_Sep - _Bot, _Range, 0) * _H + 20, 0)
VAR _Y10 = ROUND(_H - DIVIDE(_Oct - _Bot, _Range, 0) * _H + 20, 0)
VAR _Y11 = ROUND(_H - DIVIDE(_Nov - _Bot, _Range, 0) * _H + 20, 0)
VAR _Y12 = ROUND(_H - DIVIDE(_Dec - _Bot, _Range, 0) * _H + 20, 0)
VAR _X1 = 30
VAR _X2 = 30 + _Step
VAR _X3 = 30 + _Step * 2
VAR _X4 = 30 + _Step * 3
VAR _X5 = 30 + _Step * 4
VAR _X6 = 30 + _Step * 5
VAR _X7 = 30 + _Step * 6
VAR _X8 = 30 + _Step * 7
VAR _X9 = 30 + _Step * 8
VAR _X10 = 30 + _Step * 9
VAR _X11 = 30 + _Step * 10
VAR _X12 = 30 + _Step * 11
VAR _Base = _H + 20
VAR _Color = SWITCH(_Sel, "Injuries", "#244181", "Total Cost", "#0EA5A5", "Recovery Days", "#F59E0B", "#244181")
RETURN
"<style>
  .mt{font-family:Segoe UI,sans-serif;padding:10px 14px;width:100%;height:100%}
  .mt-t{font-size:14px;font-weight:800;color:#1a2b4a;margin-bottom:2px}
  .mt-st{font-size:10px;color:#8895a7;font-style:italic;margin-bottom:8px}
  .mt-svg{width:100%;height:auto}
  .mt-axis{font-family:Segoe UI,sans-serif;font-size:9px;fill:#8895a7;font-weight:600}
  .mt-val{font-family:Segoe UI,sans-serif;font-size:8px;fill:#1a2b4a;font-weight:700}
  .mt-grid{stroke:#e8ecf0;stroke-width:0.5}
  .mt-line{fill:none;stroke:" & _Color & ";stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round}
  .mt-dot{fill:#fff;stroke:" & _Color & ";stroke-width:2.5}
</style>
<div class='mt'>
  <div class='mt-t'>" & _Title & "</div>
  <div class='mt-st'>Showing: " & _Sel & " · Select parameter to switch view</div>
  <svg class='mt-svg' viewBox='0 0 " & (_W + 60) & " " & (_H + 60) & "'>
    <defs>
      <linearGradient id='areaFill' x1='0' y1='0' x2='0' y2='1'>
        <stop offset='0%' stop-color='" & _Color & "' stop-opacity='0.25'/>
        <stop offset='100%' stop-color='" & _Color & "' stop-opacity='0.02'/>
      </linearGradient>
    </defs>

    <line class='mt-grid' x1='30' y1='20' x2='" & _X12 & "' y2='20'/>
    <line class='mt-grid' x1='30' y1='" & ROUND(_H * 0.33 + 20, 0) & "' x2='" & _X12 & "' y2='" & ROUND(_H * 0.33 + 20, 0) & "'/>
    <line class='mt-grid' x1='30' y1='" & ROUND(_H * 0.66 + 20, 0) & "' x2='" & _X12 & "' y2='" & ROUND(_H * 0.66 + 20, 0) & "'/>
    <line class='mt-grid' x1='30' y1='" & _Base & "' x2='" & _X12 & "' y2='" & _Base & "'/>

    <polygon fill='url(#areaFill)' points='"
      & _X1 & "," & _Y1 & " "
      & _X2 & "," & _Y2 & " "
      & _X3 & "," & _Y3 & " "
      & _X4 & "," & _Y4 & " "
      & _X5 & "," & _Y5 & " "
      & _X6 & "," & _Y6 & " "
      & _X7 & "," & _Y7 & " "
      & _X8 & "," & _Y8 & " "
      & _X9 & "," & _Y9 & " "
      & _X10 & "," & _Y10 & " "
      & _X11 & "," & _Y11 & " "
      & _X12 & "," & _Y12 & " "
      & _X12 & "," & _Base & " "
      & _X1 & "," & _Base & "'/>

    <polyline class='mt-line' points='"
      & _X1 & "," & _Y1 & " "
      & _X2 & "," & _Y2 & " "
      & _X3 & "," & _Y3 & " "
      & _X4 & "," & _Y4 & " "
      & _X5 & "," & _Y5 & " "
      & _X6 & "," & _Y6 & " "
      & _X7 & "," & _Y7 & " "
      & _X8 & "," & _Y8 & " "
      & _X9 & "," & _Y9 & " "
      & _X10 & "," & _Y10 & " "
      & _X11 & "," & _Y11 & " "
      & _X12 & "," & _Y12 & "'/>

    <circle class='mt-dot' cx='" & _X1 & "' cy='" & _Y1 & "' r='4'/>
    <circle class='mt-dot' cx='" & _X2 & "' cy='" & _Y2 & "' r='4'/>
    <circle class='mt-dot' cx='" & _X3 & "' cy='" & _Y3 & "' r='4'/>
    <circle class='mt-dot' cx='" & _X4 & "' cy='" & _Y4 & "' r='4'/>
    <circle class='mt-dot' cx='" & _X5 & "' cy='" & _Y5 & "' r='4'/>
    <circle class='mt-dot' cx='" & _X6 & "' cy='" & _Y6 & "' r='4'/>
    <circle class='mt-dot' cx='" & _X7 & "' cy='" & _Y7 & "' r='4'/>
    <circle class='mt-dot' cx='" & _X8 & "' cy='" & _Y8 & "' r='4'/>
    <circle class='mt-dot' cx='" & _X9 & "' cy='" & _Y9 & "' r='4'/>
    <circle class='mt-dot' cx='" & _X10 & "' cy='" & _Y10 & "' r='4'/>
    <circle class='mt-dot' cx='" & _X11 & "' cy='" & _Y11 & "' r='4'/>
    <circle class='mt-dot' cx='" & _X12 & "' cy='" & _Y12 & "' r='4'/>

    <text class='mt-val' x='" & _X1 & "' y='" & (_Y1 - 10) & "' text-anchor='middle'>" & FORMAT(_Jan, _Fmt) & "</text>
    <text class='mt-val' x='" & _X2 & "' y='" & (_Y2 - 10) & "' text-anchor='middle'>" & FORMAT(_Feb, _Fmt) & "</text>
    <text class='mt-val' x='" & _X3 & "' y='" & (_Y3 - 10) & "' text-anchor='middle'>" & FORMAT(_Mar, _Fmt) & "</text>
    <text class='mt-val' x='" & _X4 & "' y='" & (_Y4 - 10) & "' text-anchor='middle'>" & FORMAT(_Apr, _Fmt) & "</text>
    <text class='mt-val' x='" & _X5 & "' y='" & (_Y5 - 10) & "' text-anchor='middle'>" & FORMAT(_May, _Fmt) & "</text>
    <text class='mt-val' x='" & _X6 & "' y='" & (_Y6 - 10) & "' text-anchor='middle'>" & FORMAT(_Jun, _Fmt) & "</text>
    <text class='mt-val' x='" & _X7 & "' y='" & (_Y7 - 10) & "' text-anchor='middle'>" & FORMAT(_Jul, _Fmt) & "</text>
    <text class='mt-val' x='" & _X8 & "' y='" & (_Y8 - 10) & "' text-anchor='middle'>" & FORMAT(_Aug, _Fmt) & "</text>
    <text class='mt-val' x='" & _X9 & "' y='" & (_Y9 - 10) & "' text-anchor='middle'>" & FORMAT(_Sep, _Fmt) & "</text>
    <text class='mt-val' x='" & _X10 & "' y='" & (_Y10 - 10) & "' text-anchor='middle'>" & FORMAT(_Oct, _Fmt) & "</text>
    <text class='mt-val' x='" & _X11 & "' y='" & (_Y11 - 10) & "' text-anchor='middle'>" & FORMAT(_Nov, _Fmt) & "</text>
    <text class='mt-val' x='" & _X12 & "' y='" & (_Y12 - 10) & "' text-anchor='middle'>" & FORMAT(_Dec, _Fmt) & "</text>

    <text class='mt-axis' x='" & _X1 & "' y='" & (_Base + 14) & "' text-anchor='middle'>Jan</text>
    <text class='mt-axis' x='" & _X2 & "' y='" & (_Base + 14) & "' text-anchor='middle'>Feb</text>
    <text class='mt-axis' x='" & _X3 & "' y='" & (_Base + 14) & "' text-anchor='middle'>Mar</text>
    <text class='mt-axis' x='" & _X4 & "' y='" & (_Base + 14) & "' text-anchor='middle'>Apr</text>
    <text class='mt-axis' x='" & _X5 & "' y='" & (_Base + 14) & "' text-anchor='middle'>May</text>
    <text class='mt-axis' x='" & _X6 & "' y='" & (_Base + 14) & "' text-anchor='middle'>Jun</text>
    <text class='mt-axis' x='" & _X7 & "' y='" & (_Base + 14) & "' text-anchor='middle'>Jul</text>
    <text class='mt-axis' x='" & _X8 & "' y='" & (_Base + 14) & "' text-anchor='middle'>Aug</text>
    <text class='mt-axis' x='" & _X9 & "' y='" & (_Base + 14) & "' text-anchor='middle'>Sep</text>
    <text class='mt-axis' x='" & _X10 & "' y='" & (_Base + 14) & "' text-anchor='middle'>Oct</text>
    <text class='mt-axis' x='" & _X11 & "' y='" & (_Base + 14) & "' text-anchor='middle'>Nov</text>
    <text class='mt-axis' x='" & _X12 & "' y='" & (_Base + 14) & "' text-anchor='middle'>Dec</text>
  </svg>
</div>"
