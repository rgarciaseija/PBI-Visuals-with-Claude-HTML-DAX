Age Gender Injury bar Chart = 
VAR _16_25_F = CALCULATE([Recorded Injuries], DimPlayer[Age Bucket] = "16 - 25", DimPlayer[Gender] = "Female")
VAR _16_25_M = CALCULATE([Recorded Injuries], DimPlayer[Age Bucket] = "16 - 25", DimPlayer[Gender] = "Male")
VAR _26_35_F = CALCULATE([Recorded Injuries], DimPlayer[Age Bucket] = "26 - 35", DimPlayer[Gender] = "Female")
VAR _26_35_M = CALCULATE([Recorded Injuries], DimPlayer[Age Bucket] = "26 - 35", DimPlayer[Gender] = "Male")
VAR _36_40_F = CALCULATE([Recorded Injuries], DimPlayer[Age Bucket] = "36 - 40", DimPlayer[Gender] = "Female")
VAR _36_40_M = CALCULATE([Recorded Injuries], DimPlayer[Age Bucket] = "36 - 40", DimPlayer[Gender] = "Male")
VAR _Max = MAX(_16_25_F, MAX(_16_25_M, MAX(_26_35_F, MAX(_26_35_M, MAX(_36_40_F, _36_40_M)))))
VAR _W1F = ROUND(DIVIDE(_16_25_F, _Max, 0) * 100, 0)
VAR _W1M = ROUND(DIVIDE(_16_25_M, _Max, 0) * 100, 0)
VAR _W2F = ROUND(DIVIDE(_26_35_F, _Max, 0) * 100, 0)
VAR _W2M = ROUND(DIVIDE(_26_35_M, _Max, 0) * 100, 0)
VAR _W3F = ROUND(DIVIDE(_36_40_F, _Max, 0) * 100, 0)
VAR _W3M = ROUND(DIVIDE(_36_40_M, _Max, 0) * 100, 0)
RETURN
"<style>
  .ac{font-family:Segoe UI,sans-serif;padding:10px 14px;width:100%;height:100%}
  .ac-t{font-size:14px;font-weight:800;color:#1a2b4a;margin-bottom:2px}
  .ac-st{font-size:10px;color:#8895a7;font-style:italic;margin-bottom:8px}
  .ac-leg{display:flex;gap:12px;margin-bottom:10px}
  .ac-leg-i{display:flex;align-items:center;gap:4px;font-size:11px;color:#5f6b7a;font-weight:600}
  .ac-leg-d{width:10px;height:10px;border-radius:3px}
  .ac-group{margin-bottom:12px}
  .ac-lbl{font-size:11px;font-weight:700;color:#5f6b7a;margin-bottom:5px}
  .ac-row{display:flex;align-items:center;gap:8px;margin-bottom:4px}
  .ac-track{flex:1;height:22px;background:#e8ecf0;border-radius:6px;overflow:hidden}
  .ac-fill{height:100%;border-radius:6px;display:flex;align-items:center;justify-content:flex-end;padding-right:8px;font-size:10px;font-weight:700;color:#fff;min-width:30px}
</style>
<div class='ac'>
  <div class='ac-t'>Recorded Injuries by Age & Gender</div>
  <div class='ac-st'>How does injury occurrence vary across age groups?</div>
  <div class='ac-leg'>
    <div class='ac-leg-i'><div class='ac-leg-d' style='background:#244181'></div>Female</div>
    <div class='ac-leg-i'><div class='ac-leg-d' style='background:#5a8fe0'></div>Male</div>
  </div>
  <div class='ac-group'>
    <div class='ac-lbl'>16 - 25</div>
    <div class='ac-row'>
      <div class='ac-track'><div class='ac-fill' style='width:" & _W1F & "%;background:linear-gradient(to right,#0d1b30,#244181)'>" & FORMAT(_16_25_F, "#,0") & "</div></div>
    </div>
    <div class='ac-row'>
      <div class='ac-track'><div class='ac-fill' style='width:" & _W1M & "%;background:linear-gradient(to right,#3a6bbf,#7aa8eb)'>" & FORMAT(_16_25_M, "#,0") & "</div></div>
    </div>
  </div>
  <div class='ac-group'>
    <div class='ac-lbl'>26 - 35</div>
    <div class='ac-row'>
      <div class='ac-track'><div class='ac-fill' style='width:" & _W2F & "%;background:linear-gradient(to right,#0d1b30,#244181)'>" & FORMAT(_26_35_F, "#,0") & "</div></div>
    </div>
    <div class='ac-row'>
      <div class='ac-track'><div class='ac-fill' style='width:" & _W2M & "%;background:linear-gradient(to right,#3a6bbf,#7aa8eb)'>" & FORMAT(_26_35_M, "#,0") & "</div></div>
    </div>
  </div>
  <div class='ac-group'>
    <div class='ac-lbl'>36 - 40</div>
    <div class='ac-row'>
      <div class='ac-track'><div class='ac-fill' style='width:" & _W3F & "%;background:linear-gradient(to right,#0d1b30,#244181)'>" & FORMAT(_36_40_F, "#,0") & "</div></div>
    </div>
    <div class='ac-row'>
      <div class='ac-track'><div class='ac-fill' style='width:" & _W3M & "%;background:linear-gradient(to right,#3a6bbf,#7aa8eb)'>" & FORMAT(_36_40_M, "#,0") & "</div></div>
    </div>
  </div>
</div>"
